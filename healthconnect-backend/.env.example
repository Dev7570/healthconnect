# ============================================
#  HealthConnect Backend — Environment Variables
# ============================================
# Copy this file to .env and fill in your values

# 🔑 RapidAPI Key (for Google Places hospital search)
# Get yours at: https://rapidapi.com/Starter_API/api/google-map-places-new-v2
GOOGLE_PLACES_API_KEY=your_rapidapi_key_here

# 🌐 Server Port
PORT=5000

# 🗄️ MongoDB Connection String
# Local:  mongodb://localhost:27017/healthconnect
# Atlas:  mongodb+srv://username:password@cluster.mongodb.net/healthconnect
MONGODB_URI=mongodb://localhost:27017/healthconnect
